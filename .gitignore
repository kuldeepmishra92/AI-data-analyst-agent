MANIFEST

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nosenv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
nosetests.xml
coverage.xml
*.cover
*.py,cover
.stats

# Jupyter Notebook
.ipynb_checkpoints

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Project-specific generated directories and databases
backend/database/*.db
backend/database/*.db-journal
backend/uploads/*
backend/reports/*
backend/charts/*

# Keep directory structures if needed, but ignore uploaded/generated files
!backend/uploads/.gitkeep
!backend/reports/.gitkeep
!backend/charts/.gitkeep

# IDEs and editors
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db
desktop.ini
